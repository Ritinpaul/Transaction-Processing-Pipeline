GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/transactions_db
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/transactions_db

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# App Settings
APP_ENV=development
LOG_LEVEL=DEBUG
MAX_UPLOAD_SIZE_MB=5
BATCH_SIZE_LLM=15
LLM_MAX_RETRIES=3
LLM_RPM_LIMIT=9

# Worker
WORKER_CONCURRENCY=2
